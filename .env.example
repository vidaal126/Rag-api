NODE_ENV=development
PORT=3000

# String de conexão do PostgreSQL usada pelo Prisma
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/rag_api2?schema=public

# Porta do PostgreSQL exposta no host pelo docker-compose (5433 para não colidir com outros projetos)
POSTGRESQL_PORT=5433

# Lista de origens CORS permitidas, separadas por vírgula (ex.: https://app.exemplo.com,https://admin.exemplo.com)
CORS_ORIGIN=

# Nível de log do Pino: trace | debug | info | warn | error
LOG_LEVEL=info
